{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Telltale Island Scorecard",
  "type": "object",
  "required": [
    "value_to_destination",
    "cost_to_try",
    "verification_distance",
    "dependency_readiness",
    "information_gain_if_fail",
    "unknown_surface",
    "coordination_cost",
    "reversibility"
  ],
  "definitions": {
    "score_with_basis": {
      "type": "object",
      "required": [
        "score",
        "basis"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "basis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "properties": {
    "value_to_destination": {
      "$ref": "#/definitions/score_with_basis"
    },
    "cost_to_try": {
      "$ref": "#/definitions/score_with_basis"
    },
    "verification_distance": {
      "$ref": "#/definitions/score_with_basis"
    },
    "dependency_readiness": {
      "$ref": "#/definitions/score_with_basis"
    },
    "information_gain_if_fail": {
      "$ref": "#/definitions/score_with_basis"
    },
    "unknown_surface": {
      "$ref": "#/definitions/score_with_basis"
    },
    "coordination_cost": {
      "$ref": "#/definitions/score_with_basis"
    },
    "reversibility": {
      "$ref": "#/definitions/score_with_basis"
    }
  }
}
