{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Telltale Island",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "scope",
    "close_criteria",
    "scorecard"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "ready",
        "sailing",
        "reached",
        "deferred",
        "blocked",
        "aborted",
        "recharted"
      ]
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "close_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scorecard": {
      "type": "object"
    }
  }
}
