{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Telltale Convergence Report",
  "type": "object",
  "required": [
    "result",
    "destination",
    "reached_islands",
    "next_recommended_island"
  ],
  "properties": {
    "result": {
      "enum": [
        "SUCCESS",
        "PARTIAL",
        "BLOCKED",
        "ABORTED",
        "MAX_ITERATIONS"
      ]
    },
    "destination": {
      "type": "string"
    },
    "reached_islands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_recommended_island": {
      "type": "string"
    }
  }
}
